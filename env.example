# Copy this file to .env in each service folder and fill in values

# ── Firebase Admin SDK (gateway + backend + simulation) ─────────────
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── PostgreSQL (backend) ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/traffic_sim

# ── Redis (backend + simulation) ────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Gateway ─────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:4000
SIMULATION_URL=http://localhost:5000
ALLOWED_ORIGIN=http://localhost:5173
PORT=3000

# ── Frontend (apps/frontend/.env) ───────────────────────────────────
VITE_GATEWAY_URL=http://localhost:3000
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
